# Postgres credentials consumed by the "db" service in docker-compose.
POSTGRES_USER=giftledger
POSTGRES_PASSWORD=change-me
POSTGRES_DB=giftledger

# SQLAlchemy connection string used by the "api" service.
# Local: host must be "db" — the service name on the compose network.
# Production uses an EXTERNAL serverless Postgres (Neon); set DATABASE_URL there
# to the Neon string INCLUDING ?sslmode=require (prefer the -pooler host), e.g.
#   postgresql+psycopg2://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/giftledger?sslmode=require
DATABASE_URL=postgresql+psycopg2://giftledger:change-me@db:5432/giftledger

# Comma-separated CORS origins allowed to call the API from the browser.
# Defaults to the local Vite dev server if unset. In production (Render) this
# is set to the frontend's URL. A bare host is treated as https.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth client id (used to verify Google Sign-In tokens).
GOOGLE_CLIENT_ID=557392690347-6vgsqh0b4cc6r7d6cbv1cgkehbrilamk.apps.googleusercontent.com

# Secret used to sign the app's own JWTs — use a strong random value in prod.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200
