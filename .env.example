# Postgres credentials consumed by the "db" service in docker-compose.
POSTGRES_USER=giftledger
POSTGRES_PASSWORD=change-me
POSTGRES_DB=giftledger

# SQLAlchemy connection string used by the "api" service.
# Host must be "db" — the service name on the compose network.
DATABASE_URL=postgresql+psycopg2://giftledger:change-me@db:5432/giftledger
